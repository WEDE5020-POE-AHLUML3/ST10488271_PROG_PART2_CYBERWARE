<Window x:Class="CyberWareASM.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberWare With ASM — Cybersecurity Chatbot"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A1A"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- ══════════════════════════════════════════
             GRADIENT BRUSHES
        ══════════════════════════════════════════ -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0F0C29" Offset="0"/>
            <GradientStop Color="#302B63" Offset="0.5"/>
            <GradientStop Color="#24243E" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SendBtnGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3B82F6" Offset="0"/>
            <GradientStop Color="#A855F7" Offset="0.5"/>
            <GradientStop Color="#EC4899" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="EndBtnGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#4B0082" Offset="0"/>
            <GradientStop Color="#EC4899" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SidebarGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#10102E" Offset="0"/>
            <GradientStop Color="#0D0D24" Offset="1"/>
        </LinearGradientBrush>

        <!-- ══════════════════════════════════════════
             SCROLLBAR STYLE
        ══════════════════════════════════════════ -->
        <Style x:Key="SlimScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="3"
                                                        Background="#A855F7"
                                                        Opacity="0.55"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar Grid.Column="1"
                                       Name="PART_VerticalScrollBar"
                                       Style="{StaticResource SlimScrollBar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════════
             SEND BUTTON
        ══════════════════════════════════════════ -->
        <Style x:Key="SendButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource SendBtnGradient}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="22,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════════
             END BUTTON
        ══════════════════════════════════════════ -->
        <Style x:Key="EndButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource EndBtnGradient}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="18,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.80"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════════
             SUBMIT BUTTON  (name screen)
        ══════════════════════════════════════════ -->
        <Style x:Key="SubmitButton" TargetType="Button">
            <Setter Property="Background"      Value="{StaticResource SendBtnGradient}"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="30,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════════
             TOPIC / QUICK-ASK BUTTON  (sidebar)
        ══════════════════════════════════════════ -->
        <Style x:Key="TopicButton" TargetType="Button">
            <Setter Property="Background"      Value="#1E1B4B"/>
            <Setter Property="Foreground"      Value="#94A3B8"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#2D2B5A"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Margin"          Value="0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0"
                                         Width="6" Height="6"
                                         Fill="#A855F7"
                                         VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Margin="8,0,0,0"
                                           Text="{TemplateBinding Content}"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontSize="{TemplateBinding FontSize}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"   Value="#2D2B5A"/>
                                <Setter TargetName="Bd" Property="BorderBrush"  Value="#A855F7"/>
                                <Setter Property="Foreground"                   Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════════
             CHAT INPUT BOX
        ══════════════════════════════════════════ -->
        <Style x:Key="ChatInput" TargetType="TextBox">
            <Setter Property="Background"               Value="#1C1C42"/>
            <Setter Property="Foreground"               Value="#F1F5F9"/>
            <Setter Property="CaretBrush"               Value="#A855F7"/>
            <Setter Property="FontSize"                 Value="14"/>
            <Setter Property="BorderThickness"          Value="1.5"/>
            <Setter Property="BorderBrush"              Value="#2D2B5A"/>
            <Setter Property="Padding"                  Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="16,0,16,0"
                                          VerticalAlignment="Center"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A855F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══════════════════════════════════════════
             NAME SCREEN INPUT BOX
        ══════════════════════════════════════════ -->
        <Style x:Key="NameInput" TargetType="TextBox">
            <Setter Property="Background"      Value="#1C1C42"/>
            <Setter Property="Foreground"      Value="#F1F5F9"/>
            <Setter Property="CaretBrush"      Value="#A855F7"/>
            <Setter Property="FontSize"        Value="15"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="BorderBrush"     Value="#2D2B5A"/>
            <Setter Property="Padding"         Value="16,12"/>
            <Setter Property="Height"          Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="16,0,16,0"
                                          VerticalAlignment="Center"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A855F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ROOT GRID — two Z-order layers -->
    <Grid>

        <!-- ══════════════════════════════════════════
             LAYER 1 ▸ NAME / WELCOME SCREEN
        ══════════════════════════════════════════ -->
        <Grid x:Name="NameScreen" Panel.ZIndex="10">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A0A1A" Offset="0"/>
                    <GradientStop Color="#0F0C29" Offset="0.45"/>
                    <GradientStop Color="#1A0A2E" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Ellipse Width="500" Height="500" Opacity="0.05"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="-160,-160,0,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#A855F7" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="420" Height="420" Opacity="0.05"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,-110,-110">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#EC4899" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="480" CornerRadius="24" Padding="48,44">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#16163A" Offset="0"/>
                        <GradientStop Color="#1E1B4B" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="60" ShadowDepth="0"
                                      Color="#A855F7" Opacity="0.28"/>
                </Border.Effect>

                <StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,6">
                        <Border Width="44" Height="44" CornerRadius="11"
                                Margin="0,0,10,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                    <GradientStop Color="#A855F7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🔐" FontSize="21"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="22" FontWeight="Bold">
                            <Run Text="Cyber"      Foreground="#3B82F6"/>
                            <Run Text="Ware"       Foreground="#A855F7"/>
                            <Run Text=" With ASM"  Foreground="#EC4899"/>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Text="CYBERSECURITY CHATBOT"
                               FontSize="10" FontWeight="Bold"
                               Foreground="#475569"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <TextBlock Text="Welcome, Agent 👋"
                               FontSize="26" FontWeight="Bold"
                               Foreground="#F1F5F9"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Please identify yourself to begin&#xA;your secure session."
                               FontSize="14" Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               LineHeight="22"
                               Margin="0,0,0,30"/>

                    <TextBlock Text="First Name"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#94A3B8" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtFirstName"
                             Style="{StaticResource NameInput}"
                             Margin="0,0,0,16"/>

                    <TextBlock Text="Last Name / Surname"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#94A3B8" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtSurname"
                             Style="{StaticResource NameInput}"
                             Margin="0,0,0,6"/>

                    <TextBlock x:Name="TxtValidation"
                               Text="⚠  The textbox cannot be null, please enter Name and Surname."
                               FontSize="12" Foreground="#EC4899"
                               TextWrapping="Wrap"
                               Visibility="Collapsed"
                               Margin="0,0,0,10"/>

                    <Button x:Name="BtnSubmitName"
                            Content="BEGIN SECURE SESSION  →"
                            Style="{StaticResource SubmitButton}"
                            Margin="0,10,0,0"
                            Click="BtnSubmitName_Click"/>

                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════
             LAYER 2 ▸ MAIN CHAT SCREEN
        ══════════════════════════════════════════ -->
        <Grid x:Name="ChatScreen" Visibility="Collapsed" Panel.ZIndex="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="76"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="268"/>
            </Grid.ColumnDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Grid.ColumnSpan="2"
                    Background="{StaticResource HeaderGradient}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="2"
                                      Color="#000000" Opacity="0.55"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="20,0,0,0">
                        <Border Width="38" Height="38" CornerRadius="10"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                    <GradientStop Color="#A855F7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🔐" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="17" FontWeight="Bold">
                                <Run Text="Cyber"     Foreground="#3B82F6"/>
                                <Run Text="Ware"      Foreground="#A855F7"/>
                                <Run Text=" With ASM" Foreground="#EC4899"/>
                            </TextBlock>
                            <TextBlock Text="CYBERSECURITY CHATBOT"
                                       FontSize="9" FontWeight="Bold"
                                       Foreground="#475569"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock x:Name="TxtHeaderStatus"
                               Grid.Column="1"
                               Text="[ SECURE SESSION ACTIVE ]"
                               FontFamily="Consolas" FontSize="11"
                               Foreground="#2D2B5A"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,20,0">
                        <Ellipse Width="8" Height="8" Fill="#22C55E"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="ONLINE"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="#22C55E"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CHAT AREA -->
            <Border Grid.Row="1" Grid.Column="0" Background="#0A0A1A">
                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Style="{StaticResource ModernScrollViewer}"
                              Padding="20,16,12,16">
                    <StackPanel x:Name="ChatMessagesPanel" Orientation="Vertical"/>
                </ScrollViewer>
            </Border>

            <!-- SIDEBAR -->
            <Border Grid.Row="1" Grid.Column="1" Grid.RowSpan="2"
                    Background="{StaticResource SidebarGradient}"
                    BorderBrush="#1E1B4B" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Style="{StaticResource ModernScrollViewer}">
                    <StackPanel Margin="16,20,16,16">

                        <Border CornerRadius="14" Padding="14" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1E1B4B" Offset="0"/>
                                    <GradientStop Color="#2D1B69" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="0"
                                                  Color="#A855F7" Opacity="0.22"/>
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Border Width="40" Height="40" CornerRadius="20"
                                            Margin="0,0,10,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#3B82F6" Offset="0"/>
                                                <GradientStop Color="#EC4899" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="👤" FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="USER INFO"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="#A855F7"/>
                                        <TextBlock x:Name="TxtSidebarName"
                                                   Text="—"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="#F1F5F9"/>
                                    </StackPanel>
                                </StackPanel>

                                <Separator Background="#2D2B5A" Margin="0,0,0,10"/>

                                <TextBlock Text="FAVOURITE TOPIC"
                                           FontSize="9" FontWeight="Bold"
                                           Foreground="#EC4899"
                                           Margin="0,0,0,4"/>
                                <TextBlock x:Name="TxtSidebarTopic"
                                           Text="Not set yet"
                                           FontSize="12"
                                           Foreground="#94A3B8"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="TOPIC" FontSize="10" FontWeight="Bold"
                                   Foreground="#3B82F6"
                                   Margin="0,0,0,10"/>

                        <Button Content="Network Security"            Tag="network security"      Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Application Security"        Tag="application security"  Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Cloud Security"              Tag="cloud security"        Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Endpoint Security"           Tag="endpoint security"     Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Threat Intelligence"         Tag="threat intelligence"   Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Incident Response"           Tag="incident response"     Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Cyber Awareness"             Tag="cyber awareness"       Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Cryptography"                Tag="cryptography"          Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Governance &amp; Compliance" Tag="governance"            Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Phishing"                    Tag="phishing"              Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Passwords"                   Tag="password"              Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Malware"                     Tag="malware"               Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Privacy"                     Tag="privacy"               Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>
                        <Button Content="Scams"                       Tag="scam"                  Style="{StaticResource TopicButton}" Click="TopicBtn_Click"/>

                        <Separator Background="#1E1B4B" Margin="0,14"/>

                        <TextBlock Text="QUICK ASKS" FontSize="10" FontWeight="Bold"
                                   Foreground="#3B82F6"
                                   Margin="0,0,0,10"/>
                        <Button Content="What can you do?" Tag="what can you do" Style="{StaticResource TopicButton}" Click="QuickBtn_Click"/>
                        <Button Content="Tell me more"     Tag="tell me more"    Style="{StaticResource TopicButton}" Click="QuickBtn_Click"/>
                        <Button Content="How are you?"     Tag="how are you"     Style="{StaticResource TopicButton}" Click="QuickBtn_Click"/>
                        <Button Content="Help"             Tag="help"            Style="{StaticResource TopicButton}" Click="QuickBtn_Click"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- INPUT BAR -->
            <Border Grid.Row="2" Grid.Column="0"
                    BorderBrush="#1E1B4B" BorderThickness="0,1,0,0"
                    Padding="16,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#10102A" Offset="0"/>
                        <GradientStop Color="#0A0A1A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="110"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TxtUserInput"
                             Grid.Column="0"
                             Style="{StaticResource ChatInput}"
                             Height="48"
                             KeyDown="TxtUserInput_KeyDown"
                             Margin="0,0,10,0"/>

                    <TextBlock Grid.Column="0"
                               Text="Ask me anything about cybersecurity…"
                               Foreground="#475569" FontSize="13"
                               IsHitTestVisible="False"
                               Margin="20,0,0,0"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=TxtUserInput}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Button x:Name="BtnSend"
                            Grid.Column="1"
                            Content="⟶  SEND"
                            Style="{StaticResource SendButton}"
                            Height="48"
                            Margin="0,0,8,0"
                            Click="BtnSend_Click"/>

                    <Button x:Name="BtnEndConvo"
                            Grid.Column="2"
                            Content="⏻  END"
                            Style="{StaticResource EndButton}"
                            Height="48"
                            Click="BtnEndConvo_Click"/>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
